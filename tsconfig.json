{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "rootDir": "src",
    "paths": {
      "@game/*": ["./src/game/*"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
